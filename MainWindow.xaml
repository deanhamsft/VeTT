<Window x:Class="Vett.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YouTube Audio Tool - Player, Trimmer"
        Height="720"
        Width="1100"
        Background="#F0F0F0">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel -->
        <StackPanel Grid.Column="0"
                    Margin="0,0,12,0">
            <TextBlock Text="Downloaded Audio Files"
                       FontWeight="Bold"
                       FontSize="14"
                       Margin="0,0,0,8"/>
            <ListBox x:Name="lstFiles"
                     Height="380"
                     SelectionChanged="lstFiles_SelectionChanged"
                     Background="White"
                     BorderBrush="#CCC"/>

            <TextBlock Text="Download from YouTube"
                       FontWeight="Bold"
                       FontSize="14"
                       Margin="0,20,0,8"/>
            <TextBox x:Name="txtYouTubeUrl"
                     Height="32"
                     Text="https://www.youtube.com/watch?v=..."
                     GotFocus="txtYouTubeUrl_GotFocus"
                     LostFocus="txtYouTubeUrl_LostFocus"/>

            <Button Content="Download Audio"
                    Height="36"
                    Margin="0,8,0,0"
                    Click="DownloadButton_Click"
                    FontWeight="Medium"/>

            <Button Content="Refresh File List"
                    Height="32"
                    Margin="0,12,0,0"
                    Click="RefreshList_Click"/>
        </StackPanel>

        <!-- Right Panel: Player + Controls -->
        <StackPanel Grid.Column="1">
            <TextBlock x:Name="txtNowPlaying"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,12"
                       Text="Select a file to play"/>

            <!-- Player Controls -->
            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,12">
                <Button Content="▶ Play"
                        Width="80"
                        Height="40"
                        Click="PlayButton_Click"/>
                <Button Content="⏸ Pause"
                        Width="80"
                        Height="40"
                        Margin="8,0"
                        Click="PauseButton_Click"/>

                <Slider x:Name="seekSlider"
                        Width="420"
                        Margin="12,0"
                        VerticalAlignment="Center"
                        ValueChanged="seekSlider_ValueChanged"
                        IsMoveToPointEnabled="True"/>

                <TextBlock x:Name="txtTime"
                           Width="110"
                           VerticalAlignment="Center"
                           FontFamily="Consolas"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,20">
                <TextBlock Text="Volume"
                           Width="50"
                           VerticalAlignment="Center"/>
                <Slider x:Name="volumeSlider"
                        Width="180"
                        Minimum="0"
                        Maximum="1"
                        Value="0.8"
                        ValueChanged="volumeSlider_ValueChanged"/>
            </StackPanel>

            <!-- Trim Controls -->
            <GroupBox Header="✂️ Trim Audio"
                      Padding="12"
                      Margin="0,0,0,15">
                <StackPanel>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,4">
                        <TextBlock Text="Start (seconds):"
                                   Width="110"
                                   VerticalAlignment="Center"/>
                        <Slider x:Name="startSlider"
                                Minimum="0"
                                Maximum="7200"
                                Width="320"
                                ValueChanged="startSlider_ValueChanged"
                                IsSnapToTickEnabled="True"
                                TickFrequency="1"/>
                        <TextBlock x:Name="txtStartTime"
                                   Width="60"
                                   Margin="8,0"
                                   VerticalAlignment="Center"
                                   Text="0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Margin="0,12,0,0">
                        <TextBlock Text="Duration (seconds):"
                                   Width="110"
                                   VerticalAlignment="Center"/>
                        <Slider x:Name="durationSlider"
                                Minimum="10"
                                Maximum="7200"
                                Width="320"
                                Value="300"
                                ValueChanged="durationSlider_ValueChanged"
                                IsSnapToTickEnabled="True"
                                TickFrequency="5"/>
                        <TextBlock x:Name="txtDuration"
                                   Width="60"
                                   Margin="8,0"
                                   VerticalAlignment="Center"
                                   Text="300"/>
                    </StackPanel>

                    <UniformGrid Columns="2"
                                 Margin="0,16,0,0">
                        <Button Content="Preview Trim"
                                Click="PreviewTrim_Click"
                                Margin="0,0,6,0"/>
                        <Button Content="Save Trimmed File"
                                Click="SaveTrim_Click"
                                Background="#27AE60"
                                Foreground="White"
                                FontWeight="Bold"/>
                    </UniformGrid>
                </StackPanel>
            </GroupBox>

            <!-- Action Buttons -->
            <UniformGrid Columns="3"
                         Rows="1"
                         Margin="0,10,0,0">
                <Button Content="Transcribe Original"
                        Height="42"
                        Click="TranscribeOriginal_Click"/>
                <Button Content="Transcribe Trimmed"
                        Height="42"
                        Click="TranscribeTrimmed_Click"/>
                <Button Content="Open Folder"
                        Height="42"
                        Click="OpenFolder_Click"/>
            </UniformGrid>
            <!-- Add this inside the right StackPanel, before the Action Buttons -->
            <StackPanel Margin="0,15,0,10">
                <TextBlock Text="Download Progress"
                           FontWeight="Medium"/>
                <ProgressBar x:Name="downloadProgress"
                             Height="18"
                             Minimum="0"
                             Maximum="100"
                             Value="0"/>

                <TextBlock Text="Transcription Progress"
                           FontWeight="Medium"
                           Margin="0,12,0,4"/>
                <ProgressBar x:Name="transcribeProgress"
                             Height="18"
                             Minimum="0"
                             Maximum="100"
                             Value="0"/>
            </StackPanel>
            <Button Content="Download Whisper Model (148 MB)"
                    Click="DownloadModelButton_Click"
                    Margin="0,10,0,0"
                    Height="36"/>
        </StackPanel>
    </Grid>
</Window>